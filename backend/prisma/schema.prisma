generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  user
  fighter
}

enum FighterStatus {
  none
  pending
  approved
  rejected
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String
  isAdmin             Boolean              @default(false)
  name                String?
  phone               String?
  userType            UserType             @default(user)
  fighterStatus       FighterStatus        @default(none)
  fighterApprovedAt   DateTime?
  acceptedTermsAt     DateTime?
  confirmedAdultAt    DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  refreshSessions     RefreshSession[]
  passwordResetTokens PasswordResetToken[]
  bookings            Booking[]
  oauthIdentities     UserOAuthIdentity[]
}

model UserOAuthIdentity {
  id             String   @id @default(cuid())
  userId         String
  provider       String
  providerUserId String
  providerEmail  String?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
}

model RefreshSession {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Fighter {
  id         String    @id @default(cuid())
  userId     String?   @unique
  gymId      String    @default("gym_default_01")
  published  Boolean   @default(false)
  name       String
  summary    String
  bio        String
  photoUrl   String?
  disciplines String[]
  mediaUrls  String[]

  wins     Int @default(0)
  losses   Int @default(0)
  draws    Int @default(0)
  yearsPro Int @default(0)

  services  Service[]
  scheduleRules FighterScheduleRule[]
  slots     Slot[]
  bookings  Booking[]
  gym       Gym       @relation(fields: [gymId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gymId])
}

model Gym {
  id            String    @id @default(cuid())
  name          String

  addressLine1  String
  addressLine2  String?
  city          String
  state         String
  postalCode    String
  countryCode   String    @default("US")

  /// IANA timezone, e.g. "America/Los_Angeles"
  timezone      String

  fighters      Fighter[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([name])
}

model Service {
  id              String  @id @default(cuid())
  fighterId       String
  fighter         Fighter @relation(fields: [fighterId], references: [id], onDelete: Cascade)
  published       Boolean @default(false)
  title           String
  durationMinutes Int
  modality        String
  priceCents      Int
  currency        String  @default("USD")
  slots           Slot[]
  bookings        Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fighterId])
}

model FighterScheduleRule {
  id        String  @id @default(cuid())
  fighterId String
  fighter   Fighter @relation(fields: [fighterId], references: [id], onDelete: Cascade)

  /// 0=Sunday .. 6=Saturday
  dayOfWeek  Int
  /// Minutes since 00:00 in America/Los_Angeles
  startMinute Int
  /// Minutes since 00:00 in America/Los_Angeles; must be > startMinute
  endMinute   Int

  active    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fighterId])
}

model Slot {
  id        String  @id @default(cuid())
  fighterId String
  fighter   Fighter @relation(fields: [fighterId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  startsAtUtc DateTime
  endsAtUtc   DateTime

  reservedUntilUtc   DateTime?
  reservedBookingId  String?
  confirmedBookingId String?

  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fighterId, serviceId, startsAtUtc])
  @@index([fighterId])
  @@index([serviceId])
}

model Booking {
  id           String   @id @default(cuid())

  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  fighterId    String
  fighter      Fighter  @relation(fields: [fighterId], references: [id], onDelete: Restrict)

  serviceId    String
  service      Service  @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  slotId       String
  slot         Slot     @relation(fields: [slotId], references: [id], onDelete: Restrict)

  status       String
  expiresAtUtc DateTime

  stripeCheckoutSessionId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([fighterId])
  @@index([serviceId])
  @@index([slotId])
}

model StripeWebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  type          String
  createdAt     DateTime @default(now())
}
